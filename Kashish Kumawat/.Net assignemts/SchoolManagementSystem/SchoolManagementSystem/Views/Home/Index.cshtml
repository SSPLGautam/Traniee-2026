@model SchoolManagementSystem.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-12">
            
            <div class="card shadow-sm border-0 mb-3 bg-dark text-white text-center rounded-3">
                <div class="card-body py-2">
                    <h5 class="m-0 fw-bold" style="color: #F5F5DC; letter-spacing: 1px; font-size: 0.9rem;">DASHBOARD</h5>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mb-4" style="background-color: #2c2f33; min-height: 180px;">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-3">
                    <p class="mb-3" style="color: #F5F5DC; font-size: 0.9rem; opacity: 0.8;">Manage your school records efficiently</p>
                    <a asp-action="SelectTable" class="btn btn-entry-square shadow-sm">
                        <div class="d-flex align-items-center">
                            <span style="font-size: 1.2rem; margin-right: 10px;">+</span>
                            <span class="fw-bold" style="letter-spacing: 1px; font-size: 0.8rem;">CREATE NEW ENTRY</span>
                        </div>
                    </a>
                </div>
            </div>

            <div class="row g-4 mb-4">
                
                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100 text-white" style="background-color: #2c2f33; border-radius: 12px; min-height: 180px;">
                        <div class="text-center py-2 fw-bold" style="background-color: #000000; color: #F5F5DC; font-size: 0.75rem; border-top-left-radius: 12px; border-top-right-radius: 12px;">
                            STUDENT STATISTICS
                        </div>
                        <div class="card-body d-flex flex-column gap-3" style="padding: 20px 15px;">
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Total Students:</span>
                                <span class="fw-bold">@Model.TotalStudents</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Students per Classroom:</span>
                                <span class="fw-bold">@(Model.TotalClassrooms > 0 ? (Model.TotalStudents / Model.TotalClassrooms) : 0)</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Active vs Inactive:</span>
                                <span class="fw-bold">@Model.ActiveStudents / @Model.InactiveStudents</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100 text-white" style="background-color: #2c2f33; border-radius: 12px; min-height: 180px;">
                        <div class="text-center py-2 fw-bold" style="background-color: #000000; color: #F5F5DC; font-size: 0.75rem; border-top-left-radius: 12px; border-top-right-radius: 12px;">
                            ATTENDANCE OVERVIEW
                        </div>
                        <div class="card-body d-flex flex-column gap-3" style="padding: 20px 15px;">
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Present Today:</span>
                                <span class="fw-bold">@Model.PresentToday</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Absent Today:</span>
                                <span class="fw-bold">@Model.AbsentToday</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Attendance Rate:</span>
                                <span class="fw-bold">@Model.AttendanceRate</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100 text-white" style="background-color: #2c2f33; border-radius: 12px; min-height: 180px;">
                        <div class="text-center py-2 fw-bold" style="background-color: #000000; color: #F5F5DC; font-size: 0.75rem; border-top-left-radius: 12px; border-top-right-radius: 12px;">
                            EXAM OVERVIEW
                        </div>
                        <div class="card-body d-flex flex-column gap-3" style="padding: 20px 15px;">
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Upcoming Exams:</span>
                                <span class="fw-bold">@Model.UpcomingExams</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Recently conducted exams:</span>
                                <span class="fw-bold">@Model.RecentlyConductedExamsCount</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Class-wise exam performance:</span>
                                <span class="fw-bold">@Model.ClassWisePerformanceCount</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card border-0 shadow-sm h-100 text-white" style="background-color: #2c2f33; border-radius: 12px; min-height: 180px;">
                        <div class="text-center py-2 fw-bold" style="background-color: #000000; color: #F5F5DC; font-size: 0.75rem; border-top-left-radius: 12px; border-top-right-radius: 12px;">
                            QUICK METRICS
                        </div>
                        <div class="card-body d-flex flex-column gap-3" style="padding: 20px 15px;">
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Total Teachers:</span>
                                <span class="fw-bold">@Model.TotalTeachers</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Total Parents registered:</span>
                                <span class="fw-bold">@Model.TotalParentsRegistered</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Number of courses offered:</span>
                                <span class="fw-bold">@Model.NumberOfCoursesOffered</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center" style="font-size: 0.85rem;">
                                <span>Total grades/sections:</span>
                                <span class="fw-bold">@Model.TotalGradesSections</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>

<style>
    body {

        background-color: #f8f9fa;
    }
    .btn-entry-square {
        background-color: transparent;
        color: #F5F5DC;
        border: 1px solid #F5F5DC;
        padding: 12px 25px;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

        .btn-entry-square:hover {
            background-color: #F5F5DC;
            color: #2c2f33;
            transform: translateY(-2px);
        }
</style>