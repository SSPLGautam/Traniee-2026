@model SchoolManagementSystem.Models.ExamResult

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Exam Result</h4>

<hr />

<div class="row">
    <div class="col-md-4">

        <form method="post" asp-action="Create">

            <div class="form-group mb-3">
                <label>Exam Id</label>

                <select asp-for="ExamId"
                        class="form-control"
                        asp-items="ViewBag.ExamId">
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Student Id</label>

                <select asp-for="StudentId"
                        class="form-control"
                        asp-items="ViewBag.StudentId">
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Course Id</label>

                <select asp-for="CourseId"
                        class="form-control"
                        asp-items="ViewBag.CourseId">
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Marks</label>

                <input asp-for="Marks" class="form-control" />
            </div>

            <div class="form-group mt-4 d-flex gap-2 align-items-center">
                <input type="submit" value="Create" class="btn btn-primary px-4 fw-bold shadow-sm" />

                <a asp-action="Index" class="btn btn-secondary px-4 fw-bold shadow-sm">
                    Back to List
                </a>
            </div>

        </form>

    </div>
</div>