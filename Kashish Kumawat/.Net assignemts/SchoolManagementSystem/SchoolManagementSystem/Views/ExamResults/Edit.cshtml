@model SchoolManagementSystem.Models.ExamResult

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Exam Result</h4>

<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label>Exam Id</label>

                <select asp-for="ExamId"
                        class="form-control"
                        asp-items="ViewBag.ExamId">
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Student Id</label>

                <select asp-for="StudentId"
                        class="form-control"
                        asp-items="ViewBag.StudentId">
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Course Id</label>

                <select asp-for="CourseId"
                        class="form-control"
                        asp-items="ViewBag.CourseId">
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Marks</label>

                <input asp-for="Marks"
                       class="form-control" />
            </div>

            <div class="form-group">

                <input type="submit"
                       value="Save"
                       class="btn btn-primary" />

                <a asp-action="Index"
                       class="btn btn-secondary">
                    Back to List
                </a>

            </div>

        </form>

    </div>
</div>