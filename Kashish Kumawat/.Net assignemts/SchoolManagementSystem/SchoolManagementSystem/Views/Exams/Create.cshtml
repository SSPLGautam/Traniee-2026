@model SchoolManagementSystem.Models.Exam

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Exam</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="ExamTypeId" class="control-label"></label>
                <select asp-for="ExamTypeId" class ="form-control" asp-items="ViewBag.ExamTypeId"></select>
            </div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="form-group mt-4 d-flex gap-2 align-items-center">
                <input type="submit" value="Create" class="btn btn-primary px-4 fw-bold shadow-sm" />

                <a asp-action="Index" class="btn btn-secondary px-4 fw-bold shadow-sm">
                    Back to List
                </a>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
